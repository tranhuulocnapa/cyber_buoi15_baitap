generator client {
  provider     = "prisma-client"
  output       = "../src/modules-system/prisma/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "mysql"
}

model binh_luan {
  binh_luan_id   Int         @id @default(autoincrement())
  nguoi_dung_id  Int?
  hinh_id        Int?
  ngay_binh_luan DateTime?   @default(now()) @db.DateTime(0)
  noi_dung       String?     @db.VarChar(500)
  hinh_anh       hinh_anh?   @relation(fields: [hinh_id], references: [hinh_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_bl_hinh")
  nguoi_dung     nguoi_dung? @relation(fields: [nguoi_dung_id], references: [nguoi_dung_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_bl_nguoi_dung")

  @@index([hinh_id], map: "fk_bl_hinh")
  @@index([nguoi_dung_id], map: "fk_bl_nguoi_dung")
}

model hinh_anh {
  hinh_id       Int         @id @default(autoincrement())
  ten_hinh      String?     @db.VarChar(255)
  duong_dan     String?     @db.VarChar(500)
  mo_ta         String?     @db.VarChar(500)
  nguoi_dung_id Int?
  created_at    DateTime?   @default(now()) @db.Timestamp(0)
  is_deleted    Boolean?    @default(false)
  binh_luan     binh_luan[]
  nguoi_dung    nguoi_dung? @relation(fields: [nguoi_dung_id], references: [nguoi_dung_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_hinh_nguoi_dung")
  luu_anh       luu_anh[]

  @@index([nguoi_dung_id], map: "fk_hinh_nguoi_dung")
  @@index([ten_hinh], map: "idx_ten_hinh")
}

model luu_anh {
  nguoi_dung_id Int
  hinh_id       Int
  ngay_luu      DateTime?  @default(now()) @db.DateTime(0)
  hinh_anh      hinh_anh   @relation(fields: [hinh_id], references: [hinh_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_luu_hinh")
  nguoi_dung    nguoi_dung @relation(fields: [nguoi_dung_id], references: [nguoi_dung_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_luu_nguoi_dung")

  @@id([nguoi_dung_id, hinh_id])
  @@index([hinh_id], map: "fk_luu_hinh")
}

model nguoi_dung {
  nguoi_dung_id Int         @id @default(autoincrement())
  email         String      @unique(map: "email") @db.VarChar(255)
  mat_khau      String      @db.VarChar(255)
  ho_ten        String?     @db.VarChar(255)
  tuoi          Int?
  anh_dai_dien  String?     @db.VarChar(255)
  created_at    DateTime?   @default(now()) @db.Timestamp(0)
  role          String?     @default("user") @db.VarChar(50)
  binh_luan     binh_luan[]
  hinh_anh      hinh_anh[]
  luu_anh       luu_anh[]

  @@index([email], map: "idx_email")
}
